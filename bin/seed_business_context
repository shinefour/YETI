def _read_jd():
    """Read the JD PDF and return as text."""
    pdf_path = ROOT / "base_knowledge" / "JD Head of Architecture.pdf"
    if not pdf_path.exists():
        return None
    try:
        import pypdf

        reader = pypdf.PdfReader(str(pdf_path))
        return "\n".join(p.extract_text() for p in reader.pages)
    except Exception as e:
        print(f"  ! Could not read JD PDF: {e}")
        return None


def main():
    if not API_KEY:
        print("ERROR: YETI_DASHBOARD_API_KEY not set in .env")
        sys.exit(1)

    print("Seeding business context to", API_URL)
    print()

    print("--- Daniel ---")
    store_drawer(DANIEL_PROFILE, "daniel", "profile")

    jd_text = _read_jd()
    if jd_text:
        store_drawer(jd_text, "daniel", "job_descriptions", source="jd_pdf")

    print()
    print("--- Companies ---")
    store_drawer(DICONVE, "diconve", "overview")
    store_drawer(GLOBALSTUDIO, "globalstudio", "overview")
    store_drawer(CONETIC, "conetic", "overview")
    store_drawer(ABOVE, "above", "overview")
    store_drawer(CASTLABS, "castlabs", "overview")

    print()
    print("--- People ---")
    for name, wing, note in PEOPLE:
        store_drawer(
            _person_drawer(name, wing, note),
            "people",
            "contacts",
        )

    print()
    print("--- Knowledge graph facts ---")
    for fact in KG_FACTS:
        kg_add(*fact)

    print()
    print("Done. Verify with:")
    print(f"  curl {API_URL}/api/memory/wings -H 'x-api-key: ***'")


if __name__ == "__main__":
    main()
