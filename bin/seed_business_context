#!/usr/bin/env python3
"""Seed YETI MemPalace with initial business context.

Adds Daniel's profile, companies, key people, and knowledge graph facts
based on base_knowledge/startingpoint.md and the JD PDF.

Run from the YETI repo root:
    .venv/bin/python bin/seed_business_context
"""

import os
import sys
from pathlib import Path

import httpx

ROOT = Path(__file__).resolve().parents[1]
ENV_FILE = ROOT / ".env"


def _load_env():
    """Load .env file."""
    if not ENV_FILE.exists():
        return
    for line in ENV_FILE.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, _, value = line.partition("=")
        os.environ.setdefault(key.strip(), value.strip())


_load_env()

API_URL = os.environ.get(
    "YETI_API_URL", "https://yeti.diconve.com"
)
API_KEY = os.environ.get("YETI_DASHBOARD_API_KEY", "")
HEADERS = {"x-api-key": API_KEY} if API_KEY else {}


def store_drawer(content: str, wing: str, room: str, source: str = "bootstrap"):
    """Add a drawer via the YETI API."""
    r = httpx.post(
        f"{API_URL}/api/memory/store",
        headers=HEADERS,
        json={
            "content": content,
            "wing": wing,
            "room": room,
            "source": source,
        },
        timeout=60,
    )
    if r.is_success:
        data = r.json()
        if "error" in data:
            print(f"  ! {wing}/{room}: {data['error']}")
            return False
        print(f"  + {wing}/{room}: {data.get('drawer_id', 'ok')}")
        return True
    print(f"  ! {wing}/{room}: HTTP {r.status_code}")
    return False


def kg_add(subject: str, predicate: str, obj: str, valid_from: str | None = None):
    """Add a knowledge graph fact."""
    payload = {
        "subject": subject,
        "predicate": predicate,
        "object": obj,
    }
    if valid_from:
        payload["valid_from"] = valid_from
    r = httpx.post(
        f"{API_URL}/api/memory/kg/add",
        headers=HEADERS,
        json=payload,
        timeout=30,
    )
    if r.is_success:
        print(f"  + {subject} --{predicate}--> {obj}")
        return True
    print(f"  ! KG fact failed: {r.status_code}")
    return False


