# YETI Environment Variables
# Copy to .env and fill in actual values

# --- Dashboard Auth ---
YETI_DASHBOARD_API_KEY=

# --- AI Model Keys ---
YETI_ANTHROPIC_API_KEY=
YETI_OPENAI_API_KEY=

# --- Telegram ---
YETI_TELEGRAM_BOT_TOKEN=
YETI_TELEGRAM_ALLOWED_CHAT_ID=

# --- Infrastructure (defaults work for Docker/Kamal) ---
YETI_OLLAMA_BASE_URL=http://ollama:11434
YETI_REDIS_URL=redis://redis:6379/0
YETI_MEMPALACE_URL=http://mempalace:3100
YETI_CHROMADB_URL=http://chromadb:8001

# --- Microsoft 365 (Teams, Calendar, Email) ---
YETI_MICROSOFT_CLIENT_ID=
YETI_MICROSOFT_CLIENT_SECRET=
YETI_MICROSOFT_TENANT_ID=
# Outlook mailboxes, comma-separated "email:wing" pairs. Each mailbox is
# hard-pinned to the named wing in MemPalace (no cross-wing routing).
# Example:
# YETI_OUTLOOK_MAILBOXES=daniel.mundt@above.aero:above,daniel.mundt@coneticgroup.com:conetic
YETI_OUTLOOK_MAILBOXES=

# --- Gmail (OAuth) ---
YETI_GMAIL_CLIENT_ID=
YETI_GMAIL_CLIENT_SECRET=
YETI_GMAIL_EMAIL=
# Wing this Gmail mailbox is pinned to (hard enforced at triage).
YETI_GMAIL_FORCED_WING=globalstudio

# --- Jira ---
YETI_JIRA_URL=
YETI_JIRA_EMAIL=
YETI_JIRA_API_TOKEN=

# --- Notion ---
YETI_NOTION_API_KEY=

# --- Slack ---
YETI_SLACK_BOT_TOKEN=

# --- Kamal Registry ---
KAMAL_REGISTRY_USERNAME=
KAMAL_REGISTRY_PASSWORD=
